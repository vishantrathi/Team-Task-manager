# Backend Environment Example
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/teamtaskmanager
JWT_ACCESS_SECRET=your_access_secret
JWT_REFRESH_SECRET=your_refresh_secret
ADMIN_INVITE_CODE=your_admin_invite_code
# Optional: extra secret for OTP HMAC (defaults to JWT_ACCESS_SECRET)
# OTP_PEPPER=your_otp_pepper
NODE_ENV=development

# Local: leave unset. Vercel + vercel.json routePrefix /_/backend: optional override (else defaults when VERCEL=1)
# SERVICE_ROUTE_PREFIX=/_/backend

# SMTP (required in production for signup OTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
